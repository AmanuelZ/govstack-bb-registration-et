# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug
API_VERSION=v1

# Database
DATABASE_URL=postgresql://govstack:govstack@localhost:5432/govstack_registration

# Redis
REDIS_URL=redis://localhost:6379

# Fayda / eSignet OIDC
FAYDA_ISSUER_URL=http://localhost:4011
FAYDA_CLIENT_ID=govstack-registration-et
FAYDA_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback
FAYDA_PRIVATE_KEY=

# JWT (internal session tokens)
JWT_SECRET=change-me-in-production-minimum-32-chars
JWT_EXPIRY=8h

# Information Mediator
IM_VALIDATE_CLIENTS=false
IM_REGISTERED_CLIENTS=ET/GOV/10000001/REGISTRATION

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Encryption (AES-256-GCM for PII fields)
ENCRYPTION_KEY=change-me-32-byte-hex-key-for-pii

# Development
MOCK_FAYDA_ENABLED=true
SEED_TEST_DATA=true
